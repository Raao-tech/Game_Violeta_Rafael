# ====================================================================
# PLAYERS (1)
# Cada player tiene su PNG en ./img_src/sprites/players/<name>.png
#
# Formato:
#   id|name|zone|pos_x|pos_y|vision_x|vision_y|gdesc(char)|max_bag|max_numens|active_num_id|active_obj_id(opcional)
#
#   id           : identificador unico del player
#   name         : nombre. Tambien es el nombre del PNG del sprite
#   zone         : id del space donde inicia
#   pos_x, pos_y : posicion en pixeles dentro del space (multiplo de SCALE)
#   vision_x/y   : posicion en pixeles que el player "mira" (para take/inspect)
#   gdesc        : char ASCII de fallback si no hay PNG
#   max_bag      : capacidad de backpack_objects
#   max_numens   : capacidad de backpack_numens
#   active_num_id: id del numen activo al inicio. -1 si todavia no se ha elegido.
#                  Para Atlas lo dejamos en -1: el menu lo asigna tras elegir starter.
#   active_obj_id: opcional. -1 o vacio si no hay objeto activo.
# ====================================================================
#p:100|Atlas|1|240|240|240|240|@|3|3|-1|


# ====================================================================
# OBJECTS (0)
# (Pendiente para sesion futura. No hay objetos en esta version.)
# ====================================================================
#o:67|Cuadrado|1|240|320|humulukumulunulu|Cuadrado|1|10|0|0|0|-1|1|2|
#o:69|Circulo|100|300|320|humulukumulunulu|Circulo|1|10|0|0|0|-1|1|1|
# ====================================================================
# CHARACTERS (0)
# (Eliminados. En esta version solo hay numens.)
# ====================================================================


# ====================================================================
# LINKS (9) — 3 caminos paralelos desde Loby hasta los 3 bosses
#
# Formato:
#   id|name|origin|destination|direction|open_otd|open_dto
#
#   direction: N=0 S=1 E=2 W=3 (en C, valor del enum Direction)
#   open_otd : 1 si origin->destination esta abierto, 0 si no
#   open_dto : 1 si destination->origin esta abierto, 0 si no
#              (si solo se da open_otd, open_dto se asume igual)
# ====================================================================
#l:401|Loby-Corridor_r|1|2|2|1|1
#l:402|Corridor_r-End_r|2|3|2|1|1
#l:403|End_r-Boss_r|3|8|1|1|1
#l:404|Loby-Corridor_l|1|4|3|1|1
#l:405|Corridor_l-End_l|4|5|3|1|1
#l:406|End_l-Boss_l|5|9|1|1|1
#l:407|Loby-Corridor_c|1|6|1|1|1
#l:408|Corridor_c-Corridor_e|6|7|1|1|1
#l:409|Corridor_e-Boss_e|7|10|1|1|1


# ====================================================================
# NUMENS (10)
# Cada numen tiene su PNG en ./img_src/sprites/numens/<name>.png
#
# Formato (16 campos):
#   id|name|zone|pos_x|pos_y|gdesc|health|energy|attack|speed|s1|s2|s3|s4|following|corrupt
#
#   id        : identificador unico
#   name      : nombre. Tambien es el nombre del PNG del sprite (case-sensitive!)
#   zone      : id del space donde vive
#   pos_x/y   : posicion en pixeles dentro del space (multiplo de SCALE)
#   gdesc     : char ASCII de fallback si no hay PNG
#   health    : puntos de vida iniciales
#   energy    : puntos de energia iniciales
#   attack    : puntos de ataque base
#   speed     : velocidad 
#   s1..s4    : ids de skills (Skills_id) que conoce. 0 = NO_SKILL
#   following : id del player al que sigue. -1 = errante (no acompaña a nadie)
#   corrupt   : 0 = amigo (capturable o starter), 1 = enemigo
#
# Distribucion:
#   Starters (1, 2, 3) — en Loby, errantes hasta que el jugador elige uno.
#                        Tras elegir, los otros dos son borrados por el game_loop.
#   Capturables (4..7) — errantes amigos, repartidos por los corredores.
#   Corruptos (8..10)  — enemigos en cada Boss room.
# ====================================================================

# --- STARTERS (escogibles al inicio) ---
#n:1|Brocochacho|1|180|260|B|10|10|3|1|1|3|0|0|-1|0|
#n:2|FairyGreen|1|260|260|S|10|10|2|1|1|3|0|0|-1|0|
#n:3|Pyjuggler|1|220|180|F|10|10|1|2|1|6|7|0|-1|0|

# --- CAPTURABLES (errantes amigos) ---
#n:4|FirePlushie|2|240|240|f|8|8|3|2|1|6|0|0|-1|0|
#n:5|LavaBall|4|240|240|l|8|8|3|2|1|6|0|0|-1|0|
#n:6|Waterlizard|6|240|240|z|8|8|3|3|1|3|0|0|-1|0|
#n:7|Arisand|7|240|240|g|8|8|3|2|1|6|0|0|-1|0|

# --- CORRUPTOS (enemigos finales) ---
#n:8|Arisand|1|240|240|N|12|10|5|2|1|6|7|0|-1|1|
#n:9|NightWater|9|240|240|N|12|10|5|3|1|3|0|0|-1|1|
#n:10|NightGround|10|240|240|N|12|10|5|2|1|6|0|0|-1|1|