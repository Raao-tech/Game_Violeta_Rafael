# ====================================================================
# Atlantic Quest — fichero de partida nueva
# Pantalla 480x480 (mapa) + 100px panel derecho + 80px panel inferior
# SCALE=40, grid 12x12 celdas (cada celda 40x40 px)
# Posiciones: en pixeles, multiplos de SCALE para encajar en celda.
# ====================================================================


# ====================================================================
# SPACES (10)
# Cada space tiene su PNG en ./img_src/background/<filename>
# Layout del juego:
#   Loby (1): hub central
#   Cor_r (2) ←E→ Loby ←W→ Cor_l (4)
#   Loby ←S→ Cor_c (6)
#   Cor_r ←S→ End_r (3) ←W→ Cor_e (7)
#   Cor_l ←S→ End_l (5)  (dead end)
#   Cor_c ←E→ Boss_r (8) ←W→ Boss_l (9)
#   Cor_c ←S→ Cor_e (7) ←S→ Boss_e (10)  final boss room
#
# Formato: id|name|gdesc(path_to_png)|OST|row0|row1|...|row11
# Cada row es WIDHT (=12) caracteres: '1'=transitable, '0'=pared
# ====================================================================
#s:1|Loby|./img_src/background/Loby.png|msc_src/OST/musica_nintendo_generica.ogg|000011111111|000011111111|000011111111|000011111111|111111111111|111111111111|111111111111|111111111111|111111110000|111111110000|111111110000|111111111111|
#s:2|Corridor_r|./img_src/background/corridor_r.png|msc_src/OST/song17.mp3|000000000000|000000000000|000000000000|000000000000|111111111111|111111111111|111111111111|111111111111|000011111111|000011111111|000011111111|111111111111|
#s:3|End_r|./img_src/background/end_r.png|msc_src/OST/musica_chill_persona_5_v2.mp3|111111111111|111111111111|111111111111|111111111111|111111111111|100011111111|100011111111|111111111111|111111111111|111111111111|111111111111|111111111111|
#s:4|Corridor_l|./img_src/background/corridor_l.png|msc_src/OST/recent_changes.ogg|110000000000|110000000000|110000000000|110000000000|111111111111|111111111111|111111111111|000011111111|000011111111|000011111111|111111111111|111111111111|
#s:5|End_l|./img_src/background/end_l.png|msc_src/OST/musica_chill_persona_5_v1.mp3|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|
#s:6|Corridor_c|./img_src/background/corridor_cent.png|msc_src/OST/Galaxy_II.mp3|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|
#s:7|Corridor_e|./img_src/background/Corridor_end.png|msc_src/OST/musica_tensa_v1.ogg|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|000011110000|000011110000|000011110000|111111111111|
#s:8|Boss_r|./img_src/background/boss_r.png|msc_src/OST/jungle_thriller.mp3|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|000011111111|000011111111|000011111111|111111111111|
#s:9|Boss_l|./img_src/background/boss_l.png|msc_src/OST/Reflection.mp3|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111110000|111111110000|111111110000|111111111111|
#s:10|Boss_e|./img_src/background/boss_e.png|msc_src/OST/the_final_countdown_musica_epica_boss.mp3|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|111111111111|100011110001|100011110001|100011110001|111111111111|


# ====================================================================
# PLAYERS (1)
# Cada player tiene su PNG en ./img_src/sprites/players/<name>.png
#
# Formato:
#   id|name|zone|pos_x|pos_y|vision_x|vision_y|gdesc(char)|max_bag|max_numens|active_num_id|active_obj_id
#
#   id           : identificador unico del player
#   name         : nombre. Tambien es el nombre del PNG del sprite
#   zone         : id del space donde inicia
#   pos_x, pos_y : posicion en pixeles dentro del space (multiplo de SCALE)
#   vision_x/y   : posicion en pixeles que el player "mira" (para take/inspect)
#   gdesc        : char ASCII de fallback si no hay PNG
#   max_bag      : capacidad de backpack_objects
#   max_numens   : capacidad de backpack_numens
#   active_num_id: id del numen activo al inicio. -1 si todavia no se ha elegido.
#                  Para Atlas lo dejamos en -1: el menu lo asigna tras elegir starter.
#   active_obj_id: -1 si no hay objeto activo al inicio.
# ====================================================================
#p:100|Atlas|1|240|240|240|320|@|3|3|-1|-1


# ====================================================================
# OBJECTS (20)
# #o: id|name|zone_id|pos_x|pos_y|description|gdesc|consumable|health|attack|energy|speed|dependency|movable|effect
# ====================================================================

